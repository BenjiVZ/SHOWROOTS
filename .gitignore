# ========================================
# SHOWROOTS / Pulsar – .gitignore
# ========================================

# ----------------------------------------
# Python / Django  (backend/)
# ----------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
venv/
.venv/
env/
ENV/

# Django
*.log
db.sqlite3
db.sqlite3-journal
backend/media/
backend/staticfiles/
backend/static_root/

# Migrations (generadas automáticamente)
# Descomenta la siguiente línea si NO quieres versionar migraciones:
# **/migrations/

# ----------------------------------------
# Node.js / Vite / Vue  (frontend/ & root)
# ----------------------------------------
node_modules/
dist/
*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ----------------------------------------
# Variables de entorno / Secretos
# ----------------------------------------
.env
.env.*
!.env.example

# ----------------------------------------
# IDEs & Editores
# ----------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ----------------------------------------
# Sistema Operativo
# ----------------------------------------
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*.directory

# ----------------------------------------
# Herramientas de agente / IA
# ----------------------------------------
.agent/
.gemini/

# ----------------------------------------
# Archivos de build / temporales
# ----------------------------------------
*.egg-info/
*.egg
*.whl
*.tar.gz
*.zip
build/
*.cache
.pytest_cache/
.mypy_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
