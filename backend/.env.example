# ────────────────────────────────────────────────────
# Pulsar / SHOWROOTS – Plantilla de variables de entorno
# Copiá este archivo a .env y completá los valores reales.
# NUNCA commitear el .env con valores reales.
# ────────────────────────────────────────────────────

# ── Django core ──
SECRET_KEY=cambiame-genera-uno-largo-con-django-secret
DEBUG=False
ALLOWED_HOSTS=pulsar.tudominio.com,api.pulsar.tudominio.com

# ── Database (Postgres en el droplet) ──
DB_ENGINE=postgres
DB_NAME=pulsar
DB_USER=pulsar_user
DB_PASSWORD=cambiame-password-fuerte
DB_HOST=localhost
DB_PORT=5432

# ── Google OAuth ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Gmail SMTP ──
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=showrootspulse@gmail.com
EMAIL_HOST_PASSWORD=app-password-de-gmail
DEFAULT_FROM_EMAIL=Pulsar <showrootspulse@gmail.com>

# ── URLs públicas (usadas en emails) ──
FRONTEND_URL=https://pulsar.tudominio.com

# ── HTTPS / Seguridad ──
SECURE_SSL_REDIRECT=True

# ── DigitalOcean Spaces (opcional pero recomendado para MEDIA) ──
# Generá un par Access Key / Secret en: cloud.digitalocean.com -> API -> Spaces Keys
USE_SPACES=False
SPACES_KEY=
SPACES_SECRET=
SPACES_BUCKET=pulsar-media
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_REGION=nyc3
# Si activás el CDN del Space, poné el hostname (ej: pulsar-media.nyc3.cdn.digitaloceanspaces.com)
SPACES_CDN=
