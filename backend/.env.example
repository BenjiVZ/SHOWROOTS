# ────────────────────────────────────────────────────
# Pulsar / SHOWROOTS – Plantilla de variables de entorno
# Copiá este archivo a .env y completá los valores reales.
# NUNCA commitear el .env con valores reales.
# ────────────────────────────────────────────────────

# ── Django core ──
SECRET_KEY=cambiame-genera-uno-largo-con-django-secret
DEBUG=False
ALLOWED_HOSTS=pulsar.tudominio.com,api.pulsar.tudominio.com

# ── Database (Postgres en el droplet) ──
DB_ENGINE=postgres
DB_NAME=pulsar
DB_USER=pulsar_user
DB_PASSWORD=cambiame-password-fuerte
DB_HOST=localhost
DB_PORT=5432

# ── Google OAuth ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Gmail SMTP ──
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=showrootspulse@gmail.com
EMAIL_HOST_PASSWORD=app-password-de-gmail
DEFAULT_FROM_EMAIL=Pulsar <showrootspulse@gmail.com>

# ── URLs públicas (usadas en emails) ──
FRONTEND_URL=https://pulsar.tudominio.com

# ── HTTPS / Seguridad ──
SECURE_SSL_REDIRECT=True

# ── Pagos (pasarela) ──
# Activa la app 'payments'. Ponelo en true para probar el checkout en SANDBOX.
# (Mantener en false deja todo el módulo de pagos apagado.)
PAYMENTS_ENABLED=true

# ── Paguelofacil (pasarela de pagos Panamá) ──
# IMPORTANTE: PFL tiene credenciales DISTINTAS para sandbox y producción.
# Confirmar con el cliente cuáles son antes de pasar a producción.
# Para verificar: python manage.py pfl_check --target sandbox
#                 python manage.py pfl_check --target production
PAGUELOFACIL_ENV=sandbox
PAGUELOFACIL_CCLW=
# Formato: PUBLIC_KEY|PRIVATE_KEY (tal cual lo da el panel de PFL en "Access token API")
PAGUELOFACIL_ACCESS_TOKEN=
# URL pública a la que PFL redirige al usuario tras 3DS (solo si usás el flujo con 3DS)
PAGUELOFACIL_RETURN_URL=https://im-pulsar.com/payment/return
# URL del webhook S2S — configurar en el panel de PFL en "Webhooks"
PAGUELOFACIL_WEBHOOK_URL=https://im-pulsar.com/api/payments/paguelofacil/webhook/
# Secret HMAC-SHA256 que entrega PFL al activar el webhook (pedirlo a soporte).
# Cuando esté seteado, el endpoint valida la firma y rechaza requests no firmadas.
# En PRODUCCIÓN sin este secret, el webhook RECHAZA todo (no procesa forjas). El
# confirm/ server-side sigue funcionando; el webhook es solo backup.
PAGUELOFACIL_WEBHOOK_SECRET=

# ── DigitalOcean Spaces (opcional pero recomendado para MEDIA) ──
# Generá un par Access Key / Secret en: cloud.digitalocean.com -> API -> Spaces Keys
USE_SPACES=False
SPACES_KEY=
SPACES_SECRET=
SPACES_BUCKET=pulsar-media
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_REGION=nyc3
# Si activás el CDN del Space, poné el hostname (ej: pulsar-media.nyc3.cdn.digitaloceanspaces.com)
SPACES_CDN=
